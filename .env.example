# ─── FlashExecutorV3 Live Execution Environment ───────────
#
# Copy this to .env and fill in your values.
# NEVER commit .env to git.
#

# Required ──────────────────────────────────────────────────

# Chain selection: "arbitrum" or "mainnet"
CHAIN=arbitrum

# Your bot wallet private key (hot wallet with gas ETH)
# This wallet owns FlashExecutorV3 and signs transactions.
BOT_PRIVATE_KEY=0x...

# Deployed FlashExecutorV3 address (set after deployment)
FLASH_EXECUTOR_V3=0x...

# Arbitrum RPC endpoints (Alchemy recommended)
ARBITRUM_HTTP_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_API_KEY
ARBITRUM_WS_URL=wss://arb-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Ethereum Mainnet RPC endpoints (required if CHAIN=mainnet)
MAINNET_HTTP_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
MAINNET_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Flashbots auth key (mainnet ONLY — generate a separate key)
# This is NOT your bot wallet key. It's used to sign Flashbots API requests.
# Generate: python3 -c "from eth_account import Account; print(Account.create().key.hex())"
FLASHBOTS_AUTH_KEY=0x...

# Optional ──────────────────────────────────────────────────

# Telegram alerting (get from @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Minimum profit threshold (default: $50 arb, $500 mainnet)
MIN_PROFIT_USD=50.0

# Dry run mode: set to "1" to simulate only, never broadcast
DRY_RUN=0

# Legacy ────────────────────────────────────────────────────
# Old scripts may still reference these:
ALCHEMY_HTTP_URL=${ARBITRUM_HTTP_URL}
